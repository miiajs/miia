{
  "name": "@miiajs/drizzle",
  "version": "0.0.1",
  "author": "Ruslan Matiushev",
  "license": "MIT",
  "description": "Drizzle ORM integration for MiiaJS (PostgreSQL, MySQL, SQLite).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miiajs/miia.git",
    "directory": "packages/drizzle"
  },
  "homepage": "https://github.com/miiajs/miia/tree/main/packages/drizzle#readme",
  "bugs": {
    "url": "https://github.com/miiajs/miia/issues"
  },
  "keywords": ["miiajs", "miia", "drizzle", "orm", "postgres", "mysql", "sqlite"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.22.1",
    "bun": ">=1.3.11",
    "deno": ">=2.6.1"
  },
  "dependencies": {
    "@miiajs/core": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": ">=0.45.2 <1.0.0",
    "mysql2": "^3.0.0",
    "postgres": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
