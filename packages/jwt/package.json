{
  "name": "@miiajs/jwt",
  "version": "0.0.1",
  "author": "Ruslan Matiushev",
  "license": "MIT",
  "description": "Injectable JWT sign/verify service for MiiaJS - a thin wrapper around jose.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miiajs/miia.git",
    "directory": "packages/jwt"
  },
  "homepage": "https://github.com/miiajs/miia/tree/main/packages/jwt#readme",
  "bugs": {
    "url": "https://github.com/miiajs/miia/issues"
  },
  "keywords": ["miiajs", "miia", "jwt", "jose", "sign", "verify", "token"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.22.1",
    "bun": ">=1.3.11",
    "deno": ">=2.6.1"
  },
  "dependencies": {
    "@miiajs/core": "workspace:*"
  },
  "peerDependencies": {
    "jose": "^6.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "jose": "^6.0.11"
  }
