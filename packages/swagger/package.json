{
  "name": "@miiajs/swagger",
  "version": "0.1.0",
  "author": "Ruslan Matiushev",
  "license": "MIT",
  "description": "OpenAPI 3.1 spec generation and Swagger UI for MiiaJS.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miiajs/miia.git",
    "directory": "packages/swagger"
  },
